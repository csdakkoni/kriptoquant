{
    "metadata": {
        "name": "vwap-zscore-lego",
        "version": "1.0.0",
        "tags": ["mean-reversion", "vwap"],
        "category": "Mean Reversion",
        "author": "KriptoQuant Scratch"
    },
    "warmupPeriod": 20,
    "indicators": [
        {
            "id": "vw",
            "type": "vwap",
            "params": [20]
        }
    ],
    "filters": [],
    "entry": {
        "type": "comparison",
        "operator": "<",
        "left": { "type": "indicator", "id": "vw" },
        "right": { "type": "constant", "value": -2.0 }
    },
    "exit": {
        "type": "comparison",
        "operator": ">",
        "left": { "type": "indicator", "id": "vw" },
        "right": { "type": "constant", "value": 2.0 }
    }
}
