{
	"metadata": {
		"name": "supertrend-trend-lego",
		"version": "1.0.0",
		"tags": ["trend-following", "supertrend", "rsi"],
		"category": "Trend",
		"author": "KriptoQuant Factory"
	},
	"warmupPeriod": 50,
	"indicators": [
		{
			"id": "st",
			"type": "supertrend",
			"params": [10, 3.0]
		},
		{
			"id": "rsi_ind",
			"type": "rsi",
			"params": [14]
		}
	],
	"filters": [
		{
			"type": "comparison",
			"operator": "<",
			"left": { "type": "indicator", "id": "rsi_ind" },
			"right": { "type": "constant", "value": 70 }
		}
	],
	"entry": {
		"type": "comparison",
		"operator": "==",
		"left": { "type": "indicator", "id": "st.direction" },
		"right": { "type": "constant", "value": 1 }
	},
	"exit": {
		"type": "comparison",
		"operator": "==",
		"left": { "type": "indicator", "id": "st.direction" },
		"right": { "type": "constant", "value": -1 }
	}
}
